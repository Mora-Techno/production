{
  "name": "fluxo",
  "private": true,
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@sinclair/typebox": "0.34.41",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.90.21",
    "axios": "^1.13.6"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.6.3"
  },
  "scripts": {
    "dev": "turbo run dev --parallel --filter=!mobile",
    "mobile": "cd apps/mobile && bun run dev",
    "mobile:clear": "cd apps/mobile && bun x expo start -c",
    "lint": "./scripts/ci-lint.sh",
    "lint:fix": "./scripts/ci-lint.sh --fix",
    "format": "bunx biome format --write apps/fe apps/be apps/mobile packages/shared",
    "format:check": "./scripts/ci-format.sh",
    "ci": "./scripts/ci-quality.sh",
    "ci:fix": "./scripts/ci-quality.sh --fix"
  }
}
